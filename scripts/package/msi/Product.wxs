<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <?define UpgradeCode="8f3c2a1b-9d4e-4f5a-b6c7-1e2d3a4b5c6d" ?>

  <Package
    Name="GoScan"
    Manufacturer="rootkit-lab"
    Version="$(var.ProductVersion)"
    UpgradeCode="$(var.UpgradeCode)"
    Scope="perMachine">
    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="Uma versão mais recente do GoScan já está instalada." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="GoScan" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Package>
</Wix>
