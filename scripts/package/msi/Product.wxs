<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <?define UpgradeCode="8f3c2a1b-9d4e-4f5a-b6c7-1e2d3a4b5c6d" ?>

  <Product
    Id="*"
    Name="GoScan"
    Language="1046"
    Version="$(var.ProductVersion)"
    Manufacturer="rootkit-lab"
    UpgradeCode="$(var.UpgradeCode)">
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="GoScan — findings e scan de .env"
      Comments="https://github.com/rootkit-lab/goscan" />

    <MajorUpgrade
      DowngradeErrorMessage="Uma versão mais recente do GoScan já está instalada."
      AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="GoScan" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLDIR" Name="GoScan">
          <Directory Id="APPDIR" Name="app" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="GoScan" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut
        Id="GoScanUIShortcut"
        Name="GoScan"
        Description="Findings, checkers e scan de .env"
        Target="[APPDIR]bin\goscan-ui.exe"
        WorkingDirectory="APPDIR" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\rootkit-lab\goscan"
        Name="installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
